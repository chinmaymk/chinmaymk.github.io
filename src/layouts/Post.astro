---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  description?: string;
}

const { title, date, description } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={`${title} — Chinmay`} description={description}>
  <article>
    <header class="article-header">
      <h1>{title}</h1>
      <div class="article-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
    <a href="/blog" class="back-link">&larr; All posts</a>
  </article>
</Base>
